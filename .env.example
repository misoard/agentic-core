# .env.example — the single env template for this repo.
# Copy to `.env` and fill in. Read from the working directory (repo root) by
# agentic_core's base Settings and by the demo's AppSettings. Everything is
# OPTIONAL — the test suite runs fully offline with none of it set.
# (When demo/ eventually becomes its own repo, it carries its own .env there.)

# --- secrets ---------------------------------------------------------------
# One key fronts every model via OpenRouter. The others are only needed if you
# point an alias straight at a provider (e.g. openai/...). Add more by the
# `<provider>_api_key` convention (declare the field on AppSettings).
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- models (env-driven, so a swap needs no code change; used by AppSettings) --
FAST_MODEL=openrouter/openai/gpt-4o-mini
SMART_MODEL=openrouter/anthropic/claude-sonnet-4.6

# --- run knobs -------------------------------------------------------------
DEFAULT_MODEL=fast
REQUEST_TIMEOUT_S=30
NUM_RETRIES=2

# Set to 1 to let live-provider tests/demo actually call out. Default 0 = offline.
LLM_LIVE_TESTS=0

# --- observability (opt-in; Logfire > Jaeger > console, first one set wins) ----
LOGFIRE_TOKEN=
JAEGER_ENDPOINT=
OTEL_CONSOLE_EXPORT=0
